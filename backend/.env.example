APP_NAME=Sayanjali Nexus CRM
ENVIRONMENT=local
DEBUG=true

# SQLite for local-first mode. Swap for a postgres:// URL later - no code changes needed.
DATABASE_URL=sqlite:///./data/sayanjali_crm.db

SECRET_KEY=replace_this_with_a_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_TIMEOUT_MINUTES=60

BACKUP_DIR=./backups
AUTO_BACKUP_INTERVAL_HOURS=24
